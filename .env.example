SECRET_KEY=replace-me
DEBUG=true


# For local development, paste the EXTERNAL Render Postgres URL here and keep sslmode=require.
# Example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
#
# On Render itself, set DATABASE_URL to the INTERNAL Render Postgres connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DATABASE_SSL_REQUIRE=true
DATABASE_CONN_MAX_AGE=600

ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

MAX_API_REQUEST_BODY_SIZE=8388608
MAX_API_FORM_FIELDS=200

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_ROOT_FOLDER=fass-us
